public class amenzi_politie {
    protected String cnp;

    public amenzi_politie(String cnp) {
        this.cnp = cnp;
    }

    public String getCnp() {
        return cnp;
    }
    public abstract double calculAmenzi();
@Override
    public String toString() {
        return "amenzi_politie{" +
                "cnp='" + cnp + '\'' +
                '}';
    }
    public abstract String getTipAmenzi();
    
}